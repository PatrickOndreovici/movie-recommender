<turbo-frame id="review-widget-<%= movie.id %>">
  <% user_rating = current_user.reviews.find_by(movie: movie)&.rating %>
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-sm font-medium text-neutral-400">Your rating:</span>
      <div class="flex items-center gap-0.5" role="group" aria-label="Rate from 1 to 5 stars">
        <% (1..5).each do |stars| %>
          <%= button_to movie_review_path(movie),
              method: :post,
              params: { review: { rating: stars } },
              form: { data: { turbo_frame: "review-widget-#{movie.id}" } },
              class: "star p-1 rounded transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500/50",
              title: "#{stars} star#{'s' if stars != 1}" do %>
            <% if user_rating && user_rating >= stars %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-amber-400 hover:text-amber-300" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            <% else %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-neutral-500 hover:text-amber-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            <% end %>
          <% end %>
        <% end %>
      </div>
      <% if user_rating %>
        <span class="text-sm text-neutral-500">(<%= user_rating %> of 5)</span>
      <% end %>
    </div>
    <% if movie.reviews.exists? %>
      <p class="text-xs text-neutral-500">
        Average: <span class="font-medium text-neutral-400"><%= movie.average_rating %></span> stars
        (<%= movie.reviews.count %> <%= 'review'.pluralize(movie.reviews.count) %>)
      </p>
    <% end %>
  </div>
</turbo-frame>