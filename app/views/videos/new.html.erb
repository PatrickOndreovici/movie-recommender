<div class="w-full flex items-center justify-center text-neutral-200 font-sans">
  <div class="w-full max-w-lg bg-neutral-900 border border-neutral-800 rounded-2xl p-8 shadow-2xl" data-controller="upload">

    <div class="mb-8 font-light">
      <h1 class="text-2xl text-white tracking-tight mb-2">Upload Movie</h1>
      <p class="text-neutral-500 text-sm">Add a new video to the platform repository.</p>
    </div>

    <!-- Metadata Inputs -->
    <div class="space-y-6">
      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-neutral-400">Movie Title</label>
        <input type="text" placeholder="e.g. Blade Runner 2049" required data-upload-target="title"
               class="w-full bg-neutral-950 border border-neutral-800 rounded-lg px-4 py-2.5 text-neutral-200 placeholder-neutral-600 focus:outline-none focus:border-neutral-600 focus:ring-1 focus:ring-neutral-600 transition-colors duration-200">
      </div>

      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-neutral-400">Synopsis</label>
        <textarea placeholder="Enter an engaging description..." required rows="3" data-upload-target="description"
                  class="w-full bg-neutral-950 border border-neutral-800 rounded-lg px-4 py-2.5 text-neutral-200 placeholder-neutral-600 focus:outline-none focus:border-neutral-600 focus:ring-1 focus:ring-neutral-600 transition-colors duration-200 resize-y"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-1.5">
          <label class="block text-sm font-medium text-neutral-400">Genre</label>
          <input type="text" placeholder="Sci-Fi" required data-upload-target="genre"
                 class="w-full bg-neutral-950 border border-neutral-800 rounded-lg px-4 py-2.5 text-neutral-200 placeholder-neutral-600 focus:outline-none focus:border-neutral-600 focus:ring-1 focus:ring-neutral-600 transition-colors duration-200">
        </div>

        <div class="space-y-1.5">
          <label class="block text-sm font-medium text-neutral-400">Release Year</label>
          <input type="number" placeholder="2017" required data-upload-target="year"
                 class="w-full bg-neutral-950 border border-neutral-800 rounded-lg px-4 py-2.5 text-neutral-200 placeholder-neutral-600 focus:outline-none focus:border-neutral-600 focus:ring-1 focus:ring-neutral-600 transition-colors duration-200">
        </div>
      </div>

      <!-- File Input -->
      <div class="space-y-1.5 pt-2">
        <label class="block text-sm font-medium text-neutral-400">Video File</label>

        <div class="relative group cursor-pointer">
          <div class="absolute inset-0 bg-neutral-800/20 group-hover:bg-neutral-800/40 border border-dashed border-neutral-700 bg-neutral-950 rounded-lg transition-colors duration-200"></div>

          <div class="relative px-6 py-8 text-center flex flex-col items-center justify-center space-y-2 pointer-events-none">
            <svg class="w-8 h-8 text-neutral-500 group-hover:text-neutral-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
            <div class="text-sm font-medium text-neutral-300 group-hover:text-white" data-upload-target="fileName">Click to select a video file</div>
            <p class="text-xs text-neutral-500">MP4, WebM or OGG (Max. 2GB)</p>
          </div>

          <input type="file" accept="video/*" required data-upload-target="file"
                 class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                 onchange="document.querySelector('[data-upload-target=fileName]').textContent = this.files[0]?.name || 'Click to select a video file'">
        </div>
      </div>

      <!-- Upload Button -->
      <div class="pt-6 space-y-3">
        <button type="button" data-action="click->upload#start" data-upload-target="submitButton"
                class="w-full bg-white text-neutral-950 font-medium py-2.5 px-4 rounded-lg hover:bg-neutral-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-neutral-900 focus:ring-white transition-all active:scale-[0.98] cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:bg-white">
          Upload Movie
        </button>

        <!-- Spinner + status (hidden until upload starts) -->
        <div data-upload-target="uploadingState" class="hidden items-center justify-center gap-2 text-neutral-400 text-sm">
          <svg class="animate-spin h-5 w-5 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span data-upload-target="uploadingText">Uploading video…</span>
        </div>
      </div>

      <!-- Progress bar (hidden until upload starts) -->
      <div data-upload-target="progressContainer" class="mt-4 hidden">
        <div class="bg-neutral-800 h-2 rounded overflow-hidden">
          <div class="bg-green-500 h-2 rounded transition-all duration-300 ease-out" data-upload-target="progressBar" style="width: 0%"></div>
        </div>
      </div>
    </div>
  </div>
</div>